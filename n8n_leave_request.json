            {
              "key": "開始日期|date",
              "includeTime": false,
              "date": "={{ $json.startDate }}"
            },
            {
              "key": "結束日期|date",
              "includeTime": false,
              "date": "={{ $json.endDate }}"
            },
            {
              "key": "所屬分店|select",
              "selectValue": "={{ $json.store }}"
            },
